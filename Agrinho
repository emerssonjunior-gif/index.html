<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agrinho 2026 - O Ouro Verde do Norte Pioneiro</title>
    <style>
        /* --- ESTILOS GERAIS (CSS) --- */
        :root {
            --verde-agro: #2c5e3b;
            --verde-claro: #4caf50;
            --marrom-cafe: #4a3728;
            --creme: #f4f1ea;
            --texto: #333;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--creme);
            color: var(--texto);
            line-height: 1.6;
        }

        /* --- HEADER --- */
        header {
            background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?q=80&w=1200') no-repeat center center/cover;
            color: white;
            text-align: center;
            padding: 100px 20px;
        }

        header h1 {
            font-size: 3rem;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        header p {
            font-size: 1.2rem;
            font-style: italic;
        }

        /* --- CRÉDITOS --- */
        .autor-box {
            background-color: var(--verde-agro);
            color: white;
            text-align: center;
            padding: 15px;
            font-weight: bold;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        /* --- CONTEÚDO PRINCIPAL --- */
        main {
            max-width: 1100px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .section-agro {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            align-items: center;
            margin-bottom: 60px;
        }

